{
  "name": "dependency-analyzer-tests",
  "version": "1.0.0",
  "description": "Playwright test suite for Dependency Analyzer",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:prod": "BASE_URL=https://www.depanalyzer.com playwright test --project=chromium",
    "test:prod:headed": "BASE_URL=https://www.depanalyzer.com playwright test --project=chromium --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.19.40",
    "playwright": "^1.60.0"
  }
}
