# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# NVD API Key (free) — without this, NVD is rate limited to 5 requests/30s
# Get yours at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Allowed frontend origins (comma-separated)
# Development:
ALLOWED_ORIGINS=http://localhost:3000
# Production (replace with your actual domain):
# ALLOWED_ORIGINS=https://yourdomain.com

# API Secret for request signing (generate with: openssl rand -hex 32)
# Must match frontend VITE_API_SECRET
API_SECRET=your_random_secret_here
